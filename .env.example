# debug, info, warn, error
RUST_LOG=info

# api port exposed by docker compose
INDEXER_PORT=8080

# default to home_dir/.kasia-indexer/mainnet, must be an existing directory with read/write permissions
# KASIA_INDEXER_DB_ROOT=

# default to mainnet, if specified, the network type to use
NETWORK_TYPE=mainnet

# if not defined, fallback to public kaspa network, if specified, the `ws://{ip}:{port}` node url
KASPA_NODE_WBORSH_URL=

# DAA-score depth used for periodic pruning/cache sizing.
# Lower values keep less historical data. For ~1 day retention, use ~86400.
INDEXER_PRUNING_DEPTH=3000000

# iOS-first push profile
PUSH_PROVIDER=apns
PUSH_IOS_ENABLED=true
PUSH_FCM_ENABLED=false

# APNs auth (required for iOS push)
PUSH_APNS_ENVIRONMENT=auto
PUSH_APNS_TEAM_ID=
PUSH_APNS_KEY_ID=
PUSH_APNS_BUNDLE_ID=com.kbeam.app
PUSH_APNS_KEY_PATH=/app/secrets/apns/AuthKey.p8
PUSH_INLINE_PAYLOAD_LIMIT=3500
PUSH_APNS_TIMEOUT_MS=15000

# Contextual push alias policy (optional hardening knobs)
PUSH_CONTEXTUAL_ALIAS_MODE=strict
PUSH_CONTEXTUAL_UNKNOWN_POLICY=drop
PUSH_CONTEXTUAL_ALLOW_LEGACY_SUFFIX=false

# Gift claim service (one-time per device)
GIFT_ENABLED=true
GIFT_AMOUNT_SOMPI=10000000
GIFT_CLAIMS_PATH=/data/mainnet/gift-claims.json
GIFT_CHALLENGE_TTL_MS=120000
GIFT_CHALLENGE_SKEW_MS=15000
GIFT_IP_RATE_LIMIT_COUNT=3
GIFT_IP_RATE_LIMIT_WINDOW_MS=86400000

# App Attest verification
GIFT_REQUIRE_APPATTEST=true
GIFT_APPATTEST_ENVIRONMENT=auto
GIFT_APPATTEST_TEAM_ID=
GIFT_APPATTEST_BUNDLE_ID=com.kbeam.app

# DeviceCheck verification
GIFT_REQUIRE_DEVICECHECK=true
GIFT_ALLOW_SIMULATOR_CLAIMS=false
GIFT_DEVICECHECK_ENVIRONMENT=auto
GIFT_DEVICECHECK_TEAM_ID=
GIFT_DEVICECHECK_KEY_ID=
GIFT_DEVICECHECK_KEY_PATH=/app/secrets/devicecheck/AuthKey.p8
GIFT_DEVICECHECK_TIMEOUT_MS=10000
# Admin-only debug secret for /v1/gift/debug/query-bit0 (leave empty to disable endpoint)
GIFT_DEVICECHECK_DEBUG_SECRET=

# Payout command must print tx id on stdout.
# Placeholders: {wallet} {sompi} {amount_kas} {claim_id}
# Example:
# GIFT_PAYOUT_COMMAND=kaspa-wallet send --to {wallet} --amount {amount_kas}
GIFT_PAYOUT_COMMAND=
GIFT_PAYOUT_TIMEOUT_MS=30000